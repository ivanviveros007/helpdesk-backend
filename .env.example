# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helpdesk_db

# JWT
JWT_SECRET=change_this_to_a_random_32_char_secret_in_production
JWT_EXPIRATION=7d

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Internal comms (shared secret with AI service)
INTERNAL_API_SECRET=change_this_to_a_random_256bit_secret

# WebSocket / CORS
FRONTEND_URL=http://localhost:3000

# App
PORT=3001
NODE_ENV=development
